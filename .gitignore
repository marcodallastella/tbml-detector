# =============================================================================
# Secrets — NEVER commit these
# =============================================================================
.env
*.pem
*.key

# =============================================================================
# Data files — large and/or regenerable, not for version control
# =============================================================================
data/comtrade.db
data/comtrade.db-shm
data/comtrade.db-wal
data/*.log
data/*.csv
data/*.json

# Keep the data/ directory itself
!data/.gitkeep

# =============================================================================
# Python
# =============================================================================
**/__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
.eggs/
MANIFEST

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# Streamlit
# =============================================================================
.streamlit/secrets.toml
